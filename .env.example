# PNW Camp Scout — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it's in .gitignore.

# --- Claude AI (Required) ---
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# --- Telegram Bot (Required for bot mode) ---
# Get from: Telegram → @BotFather → /newbot
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# --- Recreation.gov RIDB (Required for availability) ---
# Get from: https://ridb.recreation.gov/docs
RECREATION_GOV_API_KEY=YOUR_KEY_HERE

# --- Campflare (Optional — enhances availability data) ---
# Get from: https://campflare.com/api
CAMPFLARE_API_KEY=YOUR_KEY_HERE

# --- Reddit (Required for social intelligence) ---
# Create an app at: https://www.reddit.com/prefs/apps
# Type: script, redirect URI: http://localhost:8080
REDDIT_CLIENT_ID=YOUR_CLIENT_ID_HERE
REDDIT_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
REDDIT_USER_AGENT=pnw-camp-scout/1.0 (by /u/YOUR_REDDIT_USERNAME)

# --- Google Places (Optional — adds ratings/reviews) ---
# Get from: https://console.cloud.google.com → Enable Places API
GOOGLE_PLACES_API_KEY=YOUR_KEY_HERE

# --- YouTube Data API (Optional — finds camping videos) ---
# Get from: https://console.cloud.google.com → Enable YouTube Data API v3
YOUTUBE_DATA_API_KEY=YOUR_KEY_HERE
